# Configuration optimisée CSAR - Support 1000+ utilisateurs
# Copiez ces variables dans votre fichier .env

# ============================================
# PERFORMANCE - CACHE
# ============================================
# Pour développement local: database
# Pour production: redis (après installation)
CACHE_STORE=database
CACHE_PREFIX=csar_cache

# ============================================
# PERFORMANCE - SESSIONS
# ============================================
# Pour développement local: database
# Pour production: redis (après installation)
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ============================================
# PERFORMANCE - QUEUE
# ============================================
# Pour développement local: database ou sync
# Pour production: redis (après installation)
QUEUE_CONNECTION=database

# ============================================
# REDIS (À configurer en production)
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# ============================================
# PERFORMANCE - IMAGES
# ============================================
PERFORMANCE_WEBP_ENABLED=true
PERFORMANCE_IMAGE_QUALITY=85
PERFORMANCE_MAX_IMAGE_WIDTH=1920
PERFORMANCE_LAZY_LOADING=true
PERFORMANCE_OPTIMIZE_IMAGES=true

# ============================================
# PERFORMANCE - CSS/JS
# ============================================
PERFORMANCE_MINIFY_CSS=true
PERFORMANCE_MINIFY_JS=true
PERFORMANCE_COMBINE_CSS=true
PERFORMANCE_COMBINE_JS=true
PERFORMANCE_DEFER_JS=true
PERFORMANCE_CRITICAL_CSS=true

# ============================================
# PERFORMANCE - DATABASE
# ============================================
PERFORMANCE_QUERY_CACHE=true
PERFORMANCE_CONNECTION_POOLING=true
PERFORMANCE_SLOW_QUERY_LOG=false

# ============================================
# PERFORMANCE - HTTP
# ============================================
PERFORMANCE_HTTP_COMPRESSION=true
PERFORMANCE_ETAGS=true
PERFORMANCE_EXPIRES=true
PERFORMANCE_MAX_AGE=31536000

# ============================================
# PERFORMANCE - CDN (Production uniquement)
# ============================================
PERFORMANCE_CDN_ENABLED=false
PERFORMANCE_CDN_URL=
PERFORMANCE_CDN_IMAGES=true
PERFORMANCE_CDN_CSS=true
PERFORMANCE_CDN_JS=true

# ============================================
# PERFORMANCE - MONITORING
# ============================================
PERFORMANCE_MONITORING=false
PERFORMANCE_SLOW_REQUEST_THRESHOLD=2000
PERFORMANCE_MEMORY_THRESHOLD=128

# ============================================
# PERFORMANCE - SEARCH
# ============================================
PERFORMANCE_SEARCH_ENABLED=true
PERFORMANCE_SEARCH_CACHE=true
PERFORMANCE_SEARCH_CACHE_TTL=1800
PERFORMANCE_SEARCH_MAX_RESULTS=20

# ============================================
# PERFORMANCE - PAGINATION
# ============================================
PERFORMANCE_PAGINATION_DEFAULT=12
PERFORMANCE_PAGINATION_MAX=50

# ============================================
# PERFORMANCE - API
# ============================================
PERFORMANCE_API_RATE_LIMITING=true
PERFORMANCE_API_RATE_LIMIT=60
PERFORMANCE_API_CACHE=true
PERFORMANCE_API_COMPRESSION=true

# ============================================
# LINKEDIN - Intégration flux actualités
# ============================================
# URL de la page entreprise LinkedIn
LINKEDIN_COMPANY_URL=https://www.linkedin.com/company/commissariat-%C3%A0-la-s%C3%A9curit%C3%A9-alimentaire-et-%C3%A0-la-r%C3%A9silience/posts/?feedView=all
# Code embed Elfsight (optionnel) - Créer un widget gratuit sur https://elfsight.com/linkedin-feed-widget/
# LINKEDIN_FEED_EMBED=

# ============================================
# NOTES D'UTILISATION
# ============================================
# 
# DÉVELOPPEMENT LOCAL (XAMPP):
# - Gardez CACHE_STORE=database
# - Gardez SESSION_DRIVER=database
# - Gardez QUEUE_CONNECTION=database
# - Activez les optimisations d'images
# 
# PRODUCTION (avec Redis):
# - Changez CACHE_STORE=redis
# - Changez SESSION_DRIVER=redis
# - Changez QUEUE_CONNECTION=redis
# - Configurez REDIS_PASSWORD
# - Activez CDN si disponible
# - Activez MONITORING
# 
# COMMANDES UTILES:
# - php artisan config:cache (après modification)
# - php artisan csar:optimize (vérification complète)
# - php artisan cache:clear (nettoyage cache)
