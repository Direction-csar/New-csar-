APP_NAME=CSAR
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# OPENWEATHERMAP CONFIGURATION - Météo en temps réel
# https://openweathermap.org/api → S'inscrire → API Keys
# Plan gratuit suffisant (60 appels/min, cache 10 min côté serveur)
# =============================================================================
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# =============================================================================
# PAYPAL CONFIGURATION - Paiement international
# https://developer.paypal.com
# =============================================================================
# Mode: 'sandbox' pour test, 'live' pour production
PAYPAL_MODE=sandbox

# Credentials depuis https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# URLs de callback (auto-générées si vides)
# PAYPAL_RETURN_URL=
# PAYPAL_CANCEL_URL=

# Configuration des montants (en USD)
PAYPAL_MIN_AMOUNT=1
PAYPAL_MAX_AMOUNT=10000
PAYPAL_CURRENCY=USD

# =============================================================================
# PAYDUNYA CONFIGURATION - Paiement mobile Sénégal
# https://paydunya.com
# =============================================================================
# Mode: 'test' pour sandbox, 'live' pour production
PAYDUNYA_MODE=test

# Clés API depuis le dashboard PayDunya (https://paydunya.com/secure/
PAYDUNYA_API_KEY=your_api_key_here
PAYDUNYA_PRIVATE_KEY=your_private_key_here
PAYDUNYA_TOKEN=your_token_here
PAYDUNYA_MASTER_KEY=your_master_key_here

# URLs de callback (auto-générées si laissées vides)
# PAYDUNYA_CALLBACK_URL=
# PAYDUNYA_RETURN_URL=
# PAYDUNYA_CANCEL_URL=

# Configuration des montants
PAYDUNYA_MIN_AMOUNT=500
PAYDUNYA_MAX_AMOUNT=1000000
PAYDUNYA_CURRENCY=XOF

# =============================================================================
# SMS NOTIFICATIONS CONFIGURATION
# =============================================================================
SMS_ENABLED=false
SMS_PROVIDER=orange
SMS_API_KEY=
SMS_SENDER_NAME=CSAR

# Orange SMS API (Sénégal)
ORANGE_SMS_CLIENT_ID=
ORANGE_SMS_CLIENT_SECRET=
ORANGE_SMS_SENDER=CSAR
ORANGE_SMS_COUNTRY_CODE=221

# Autres providers (optionnel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================================
# GOOGLE OAUTH (Admin Login)
# https://console.cloud.google.com/apis/credentials
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/admin/login/google/callback

# =============================================================================
# LINKEDIN INTEGRATION
# =============================================================================
LINKEDIN_COMPANY_URL=https://www.linkedin.com/company/csar
LINKEDIN_FEED_EMBED=

# =============================================================================
# NEWSLETTER CONFIGURATION
# =============================================================================
NEWSLETTER_PROVIDER=mailchimp
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=
NEWSLETTER_FROM_NAME=CSAR
NEWSLETTER_REPLY_TO=noreply@csar.sn

# =============================================================================
# Example env file — copy to .env and fill in your actual values
